{
  "manifest_version": 3,
  "name": "Chrome2Console",
  "version": "1.0",
  "description": "Send selected text to a local console command and replace it with the output.",
  "permissions": [
    "nativeMessaging",
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
